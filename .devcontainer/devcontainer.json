{
    "name": "SVM_Dev_Env",
    "build": {
        "dockerfile": "../Dockerfile",
        "context": ".."
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-vscode.cpptools",
                "njpwerner.autodocstring"
            ]
        }
    },
    "mounts": [
        "source=${localWorkspaceFolder},target=/workspace,type=bind"
    ],
    // Automatically attempts to pass the host GPU to the Docker container (Works for WSL2/Linux with Nvidia). 
    // Ignore if running on Mac OS Apple Silicon, as Rosetta 2 handles GPU natively differently.
    "runArgs": [
        "--gpus",
        "all"
    ],
    "remoteUser": "root"
}